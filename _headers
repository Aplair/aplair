/*
  # Static assets - cache for 1 year
  /assets/css/*.css
    Cache-Control: public, max-age=31536000, immutable
  /assets/js/*.js
    Cache-Control: public, max-age=31536000, immutable
  /assets/images/*
    Cache-Control: public, max-age=31536000, immutable

  # HTML - short cache, always revalidate
  /*.html
    Cache-Control: public, max-age=0, must-revalidate
  /
    Cache-Control: public, max-age=0, must-revalidate
